rules_version = '2';

// SafePoint — Firebase Storage Security Rules
// Accès limité aux utilisateurs authentifiés de la même organisation.

service firebase.storage {
  match /b/{bucket}/o {

    // Lecture/écriture uniquement pour les utilisateurs authentifiés
    match /organizations/{organizationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Bloc tout le reste
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
